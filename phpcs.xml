<?xml version="1.0"?>
<ruleset name="MarekSkopal PSR12"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/squizlabs/php_codesniffer/phpcs.xsd">
    <file>src/</file>
    <file>tests/</file>
    <rule ref="ruleset.xml"/>
    <rule ref="PSR1.Classes.ClassDeclaration.MultipleClasses">
        <exclude-pattern>tests/TestFile/TestFileTwoClass.php</exclude-pattern>
    </rule>
    <rule ref="Squiz.Classes.ClassFileName.NoMatch">
        <exclude-pattern>tests/TestFile/TestFileTwoClass.php</exclude-pattern>
    </rule>
    <rule ref="SlevomatCodingStandard.Files.TypeNameMatchesFileName.NoMatchBetweenTypeNameAndFileName">
        <exclude-pattern>tests/TestFile/TestFileTwoClass.php</exclude-pattern>
    </rule>
</ruleset>
